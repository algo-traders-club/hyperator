# Hyperator configuration (PRD section 4). Copy to .env and fill in your keys.

# Your Hyperliquid API wallet private key.
HYPERLIQUID_API_KEY=
# The main wallet address the API wallet is approved for.
HYPERLIQUID_MAIN_WALLET=

# Safety switches. Defaults are the safe configuration (PRD section 3).
# TESTNET=false + DRY_RUN=false is the ONLY state that risks real money.
TESTNET=true
DRY_RUN=true

SYMBOL=HYPE/USDC:USDC
TIMEFRAME=1h
TICK_INTERVAL_SECONDS=60
MAX_POSITION_USD=50
MAX_OPEN_POSITIONS=1
LOG_LEVEL=INFO
